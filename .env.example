OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# JWT signing secret — must be at least 32 characters; change before deploying
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars

# AES-256 encryption key for storing user provider keys — exactly 32 hex bytes (64 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
